{
  "expo": {
    "name": "BizBridge",
    "slug": "bizbridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "bizbridge",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#DC143C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bizbridge.mobile",
      "associatedDomains": [
        "applinks:bizbridge.ng",
        "applinks:www.bizbridge.ng"
      ]
    },
    "android": {
      "package": "com.bizbridge.mobile",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "bizbridge.ng",
              "pathPrefix": "/services"
            },
            {
              "scheme": "https",
              "host": "bizbridge.ng",
              "pathPrefix": "/artisans"
            },
            {
              "scheme": "https",
              "host": "www.bizbridge.ng",
              "pathPrefix": "/services"
            },
            {
              "scheme": "https",
              "host": "www.bizbridge.ng",
              "pathPrefix": "/artisans"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
